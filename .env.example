# --- Server ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# --- Database (Postgres) ---
# Local dev:   postgres://user:pass@localhost:5432/schoolpay
# Neon:        postgres://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
# Vercel PG:   use the DATABASE_URL Vercel injects
DATABASE_URL=postgres://user:pass@localhost:5432/schoolpay
DATABASE_POOL_MAX=5

# --- Security ---
# 32-byte hex string used for encrypting provider API credentials at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string

# JWT secrets - use strong random values in production.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# --- Rate Limiting ---
# If UPSTASH_* are set the app uses Redis-backed limits; otherwise in-memory.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Webhook ---
WEBHOOK_SHARED_SECRET=replace_with_webhook_secret

# --- Payment Providers (sandbox defaults) ---
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
ORANGE_BASE_URL=https://api.orange.com/orange-money-webpay
